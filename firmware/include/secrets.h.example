// ===== secrets.h =====
// Fill these in, then add this file to .gitignore so creds never hit the repo.
// The OTA_PASS here MUST match the --auth value in platformio.ini.
 
#pragma once
 
#define WIFI_SSID  "your-wifi-name"
#define WIFI_PASS  "your-wifi-password"
#define OTA_PASS   "CHANGE_ME_OTA"     // pick a password; mirror it in platformio.ini
 